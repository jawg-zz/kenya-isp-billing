# ===========================================
# ISP Billing System — Production Environment
# ===========================================
# Copy to .env in Dokploy and fill in ALL values.
# Generate secrets: openssl rand -base64 48 (for JWT) / openssl rand -hex 16 (for RADIUS)

# ─── Server ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=https://isp.yourdomain.com

# ─── Database ***REQUIRED*** ──────────────────────────────────────
DATABASE_URL=postgresql://isp_billing:STRONG_PASSWORD@db-host:5432/isp_billing?schema=public

# ─── Redis ***REQUIRED*** ─────────────────────────────────────────
REDIS_URL=redis://redis-host:6379

# ─── JWT ***REQUIRED*** ───────────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=generate_with_openssl_rand_base64_48
JWT_REFRESH_EXPIRES_IN=30d

# ─── M-Pesa (Safaricom Daraja) ***REQUIRED for M-Pesa payments*** ─
MPESA_CONSUMER_KEY=your_live_consumer_key
MPESA_CONSUMER_SECRET=your_live_consumer_secret
MPESA_PASSKEY=your_live_passkey
MPESA_SHORTCODE=your_till_or_paybill_number
MPESA_ENVIRONMENT=production
MPESA_CALLBACK_URL=https://isp.yourdomain.com/api/v1/payments/mpesa/callback
MPESA_TIMEOUT_URL=https://isp.yourdomain.com/api/v1/payments/mpesa/timeout
# MPESA_CERT_PATH=/path/to/safaricom_production_cert.pem

# ─── Airtel Money Kenya ***REQUIRED for Airtel payments*** ────────
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_SHORTCODE=your_airtel_shortcode
AIRTEL_ENVIRONMENT=production
AIRTEL_CALLBACK_URL=https://isp.yourdomain.com/api/v1/payments/airtel/callback
AIRTEL_CALLBACK_SECRET=your_airtel_webhook_secret
AIRTEL_ALLOWED_IPS=196.216.169.10,196.216.169.11

# ─── SMS (Africa's Talking) ***REQUIRED for phone verification*** ─
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_SENDER_ID=ISPBILLING

# ─── Email (SMTP) ***REQUIRED for email verification/invoices*** ──
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=https://isp.yourdomain.com

# ─── RADIUS ***REQUIRED for network access control*** ─────────────
RADIUS_SECRET=generate_with_openssl_rand_hex_16
RADIUS_HOST=your_radius_server_ip
RADIUS_PORT=1812
RADIUS_ACCOUNTING_PORT=1813
RADIUS_COA_PORT=3799

# ─── Invoice Branding ─────────────────────────────────────────────
INVOICE_COMPANY_NAME=Your ISP Ltd
INVOICE_COMPANY_ADDRESS=P.O. Box 12345, Nairobi, Kenya
INVOICE_COMPANY_PHONE=+254 700 123456
INVOICE_COMPANY_EMAIL=billing@yourdomain.com
INVOICE_COMPANY_KRA_PIN=P051234567A

# ─── Business Rules ───────────────────────────────────────────────
DEFAULT_CURRENCY=KES
TAX_RATE=0.16
TAX_NAME=VAT
FUP_ENABLED=true
GRACE_PERIOD_DAYS=3

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs
