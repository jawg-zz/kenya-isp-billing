# ===========================================
# ISP Billing System - Environment Variables
# ===========================================
# Copy this file to .env and fill in ALL required values.
# Required fields are marked with ***REQUIRED***

# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3001

# Database ***REQUIRED***
DATABASE_URL=postgresql://isp_billing:isp_billing_password@localhost:5432/isp_billing?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT ***REQUIRED*** - Generate strong random values (use: openssl rand -base64 48)
JWT_SECRET=***REQUIRED***_generate_with_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=***REQUIRED***_generate_with_openssl_rand_base64_48
JWT_REFRESH_EXPIRES_IN=30d

# M-Pesa Daraja API (Safaricom)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/mpesa/callback
MPESA_TIMEOUT_URL=https://your-domain.com/api/v1/payments/mpesa/timeout
# Path to Safaricom public certificate for callback signature verification (production)
# MPESA_CERT_PATH=/path/to/safaricom_cert.pem

# Airtel Money Kenya
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_SHORTCODE=your_airtel_shortcode
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CALLBACK_URL=https://your-domain.com/api/v1/payments/airtel/callback

# Africa's Talking SMS
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_SENDER_ID=ISPBILLING

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@isp-kenya.co.ke

# RADIUS Configuration ***REQUIRED*** - Generate secret with: openssl rand -hex 16
# RADIUS IP Allowlist - Comma-separated list of allowed NAS device IPs (REQUIRED)
RADIUS_ALLOWED_IPS=***REQUIRED***_comma_separated_nas_ips
RADIUS_SECRET=***REQUIRED***_generate_with_openssl_rand_hex_16
RADIUS_HOST=127.0.0.1
RADIUS_PORT=1812
RADIUS_ACCOUNTING_PORT=1813

# PDF Invoice
INVOICE_COMPANY_NAME=Your ISP Limited
INVOICE_COMPANY_ADDRESS=P.O. Box 12345, Nairobi, Kenya
INVOICE_COMPANY_PHONE=+254 700 123456
INVOICE_COMPANY_EMAIL=billing@yourisp.co.ke
INVOICE_COMPANY_KRA_PIN=P051234567A

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Business Configuration
DEFAULT_CURRENCY=KES
TAX_RATE=0.16
TAX_NAME=VAT
FUP_ENABLED=true
GRACE_PERIOD_DAYS=3
