# =============================================
# ISP Billing Frontend — Environment Variables
# =============================================
# Copy this file to .env.local and fill in values.
# Required: NEXT_PUBLIC_API_URL

# Backend API URL (no trailing slash)
# In production this MUST be set to your API server URL
# e.g. https://api.yourisp.com or http://localhost:3001
NEXT_PUBLIC_API_URL=

# Optional: Google Analytics / other tracking
# NEXT_PUBLIC_GA_ID=

# Optional: Sentry DSN for error monitoring
# NEXT_PUBLIC_SENTRY_DSN=
