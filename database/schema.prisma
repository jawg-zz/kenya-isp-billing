generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles
enum UserRole {
  ADMIN
  SUPPORT
  CUSTOMER
}

// Account status
enum AccountStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  PENDING_VERIFICATION
}

// Subscription type
enum SubscriptionType {
  PREPAID
  POSTPAID
}

// Billing cycle for postpaid
enum BillingCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// Plan data type
enum DataType {
  DATA
  VOICE
  SMS
  BUNDLE
}

// Payment status
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  TIMEOUT
}

// Payment method
enum PaymentMethod {
  MPESA
  AIREL_MONEY
  CASH
  BANK_TRANSFER
  CARD
}

// Invoice status
enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// Notification type
enum NotificationType {
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  INVOICE_GENERATED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  SUBSCRIPTION_ACTIVATED
  FUP_THRESHOLD
  ACCOUNT_SUSPENDED
  ACCOUNT_REINSTATED
  WELCOME
}

// Network provider
enum NetworkProvider {
  SAFARICOM
  AIRTEL
  TELKOM
  OTHER
}

// Session status
enum SessionStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

// User model
model User {
  id                String          @id @default(uuid())
  email             String          @unique
  password          String
  role              UserRole        @default(CUSTOMER)
  firstName         String
  lastName          String
  phone             String          @unique
  phoneVerified     Boolean         @default(false)
  emailVerified     Boolean         @default(false)
  accountStatus     AccountStatus   @default(PENDING_VERIFICATION)
  networkProvider   NetworkProvider?
  preferredPayment  PaymentMethod?
  addressLine1      String?
  addressLine2      String?
  city              String?
  county            String?         // Kenyan county
  postalCode        String?
  idNumber          String?         // Kenyan national ID
  kraPin            String?         // KRA PIN for tax
  metadata          Json?
  lastLoginAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  customer          Customer?
  subscriptions     Subscription[]
  payments          Payment[]
  notifications     Notification[]
  sessions          RadiusSession[]
  usageRecords      UsageRecord[]
  refreshTokens     RefreshToken[]

  @@index([phone])
  @@index([county])
  @@map("users")
}

// Refresh token for JWT rotation
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Customer profile (extended user info for customers)
model Customer {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerCode    String   @unique
  accountNumber   String   @unique
  balance         Decimal  @default(0)
  creditLimit     Decimal  @default(0)
  notes           String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subscriptions   Subscription[]
  invoices        Invoice[]
  payments        Payment[]
  usageRecords    UsageRecord[]
  radiusConfig    RadiusConfig?

  @@index([customerCode])
  @@index([accountNumber])
  @@map("customers")
}

// Data/Service plans
model Plan {
  id                String          @id @default(uuid())
  name              String
  description       String?
  code              String          @unique
  type              SubscriptionType
  dataType          DataType        @default(DATA)
  price             Decimal
  currency          String          @default("KES")
  dataAllowance     BigInt?         // In bytes, null for unlimited
  voiceMinutes      Int?            // Voice minutes included
  smsAllowance      Int?            // SMS included
  speedLimit        Int?            // Speed in Mbps, null for unlimited
  billingCycle      BillingCycle?
  validityDays      Int             @default(30) // For prepaid bundles
  fupThreshold      BigInt?         // Fair usage policy threshold in bytes
  fupSpeedLimit     Int?            // Speed after FUP in Mbps
  isActive          Boolean         @default(true)
  isFeatured        Boolean         @default(false)
  sortOrder         Int             @default(0)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  subscriptions     Subscription[]
  planPrices        PlanPrice[]

  @@index([code])
  @@index([type])
  @@index([isActive])
  @@map("plans")
}

// Plan pricing for different billing cycles
model PlanPrice {
  id          String      @id @default(uuid())
  planId      String
  plan        Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  billingCycle BillingCycle
  price       Decimal
  currency    String      @default("KES")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([planId, billingCycle])
  @@map("plan_prices")
}

// Customer subscriptions
model Subscription {
  id                String          @id @default(uuid())
  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan            @relation(fields: [planId], references: [id])
  status            AccountStatus   @default(ACTIVE)
  type              SubscriptionType
  dataUsed          BigInt          @default(0)
  dataRemaining     BigInt?
  voiceMinutesUsed  Int             @default(0)
  smsUsed           Int             @default(0)
  startDate         DateTime
  endDate           DateTime
  autoRenew         Boolean         @default(true)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  payments          Payment[]
  invoices          Invoice[]
  sessions          RadiusSession[]
  usageRecords      UsageRecord[]

  @@index([customerId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// Invoices
model Invoice {
  id                String          @id @default(uuid())
  invoiceNumber     String          @unique
  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id])
  subscriptionId    String?
  subscription      Subscription?   @relation(fields: [subscriptionId], references: [id])
  status            InvoiceStatus   @default(PENDING)
  subtotal          Decimal
  taxRate           Decimal         @default(0.16)
  taxAmount         Decimal
  totalAmount       Decimal
  currency          String          @default("KES")
  dueDate           DateTime
  paidAt            DateTime?
  cancelledAt       DateTime?
  notes             String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  payments          Payment[]

  @@index([customerId])
  @@index([status])
  @@index([invoiceNumber])
  @@index([dueDate])
  @@map("invoices")
}

// Payments
model Payment {
  id                String          @id @default(uuid())
  paymentNumber     String          @unique
  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id])
  invoiceId         String?
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id])
  subscriptionId    String?
  subscription      Subscription?   @relation(fields: [subscriptionId], references: [id])
  userId            String?
  user              User?           @relation(fields: [userId], references: [id])
  amount            Decimal
  currency          String          @default("KES")
  method            PaymentMethod
  status            PaymentStatus   @default(PENDING)
  reference         String?         // External reference from payment provider
  checkoutRequestId String?         // M-Pesa checkout request ID
  merchantRequestId String?         // M-Pesa merchant request ID
  resultCode        String?         // Provider result code
  resultDesc        String?         // Provider result description
  metadata          Json?
  processedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([reference])
  @@index([checkoutRequestId])
  @@index([createdAt])
  @@map("payments")
}

// RADIUS user configuration
model RadiusConfig {
  id            String    @id @default(uuid())
  customerId    String    @unique
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  username      String    @unique
  password      String
  nasIpAddress  String?
  nasPortId     String?
  poolName      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([username])
  @@map("radius_configs")
}

// RADIUS sessions
model RadiusSession {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  sessionId       String        @unique
  nasIpAddress    String
  nasPortId       String?
  nasPortType     String?
  framedIpAddress String?
  framedProtocol  String?
  startTime       DateTime      @default(now())
  stopTime        DateTime?
  status          SessionStatus @default(ACTIVE)
  inputOctets     BigInt        @default(0)
  outputOctets    BigInt        @default(0)
  totalOctets     BigInt        @default(0)
  inputPackets    BigInt        @default(0)
  outputPackets   BigInt        @default(0)
  terminateCause  String?
  metadata        Json?

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([nasIpAddress])
  @@map("radius_sessions")
}

// Usage records for billing and monitoring
model UsageRecord {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  sessionId       String?
  timestamp       DateTime  @default(now())
  inputOctets     BigInt    @default(0)
  outputOctets    BigInt    @default(0)
  totalOctets     BigInt    @default(0)
  inputPackets    BigInt    @default(0)
  outputPackets   BigInt    @default(0)
  nasIpAddress    String?
  ipAddress       String?
  metadata        Json?

  @@index([userId])
  @@index([customerId])
  @@index([timestamp])
  @@index([subscriptionId])
  @@map("usage_records")
}

// Notifications
model Notification {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String
  channel     String           @default("in_app") // in_app, sms, email
  sentVia     String?          // sms, email, push
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

// System settings
model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  category    String   @default("general")
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
  @@map("system_settings")
}

// Audit log
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// Decimal support for Prisma
type Decimal = Decimal
